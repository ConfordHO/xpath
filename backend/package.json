{
  "name": "backend",
  "version": "1.0.0",
  "description": "Backend API for the X-PATH LIMS replica",
  "main": "dist/src/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/src/server.js",
    "test": "node --import tsx --test tests/**/*.test.ts",
    "seed": "tsx scripts/seed.ts",
    "migrate:postgres": "tsx scripts/migrate-to-postgres.ts"
  },
  "keywords": [
    "express",
    "api",
    "lims"
  ],
  "author": "",
  "license": "ISC",
  "type": "module",
  "engines": {
    "node": ">=20 <26"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1028.0",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dotenv": "^17.3.1",
    "express": "^5.1.0",
    "express-rate-limit": "^8.3.2",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "mongodb": "^7.1.1",
    "multer": "^2.1.1",
    "pg": "^8.20.0",
    "tesseract.js": "^7.0.0",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^24.12.0",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^7.2.0",
    "supertest": "^7.2.2",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}
