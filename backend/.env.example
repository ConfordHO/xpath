PORT=4000
NODE_ENV=production
TRUST_PROXY=true
CORS_ORIGIN=http://localhost:3000,https://olyvia.xpath-labs.com,https://xpath-two.vercel.app,https://x-path.vercel.app,http://localhost:3002

DATABASE_URL=postgresql://username:password@host:5432/xpath
DATABASE_SSL_MODE=require
POSTGRES_STATE_TABLE=app_state
POSTGRES_STATE_ID=primary
POSTGRES_EXTERNAL_HOST_SUFFIX=oregon-postgres.render.com
HEALTH_DIAGNOSTICS_TOKEN=

# Optional one-time migration source
LEGACY_MONGODB_URI=
LEGACY_MONGODB_DB_NAME=xpath_lims
LEGACY_MONGODB_COLLECTION=app_state

JWT_SECRET=replace-with-a-long-random-secret
JWT_ISSUER=xpath-backend
JWT_AUDIENCE=xpath-clients
JWT_EXPIRY=7d

GENERAL_RATE_LIMIT_WINDOW_MS=60000
GENERAL_RATE_LIMIT_MAX=400
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=20
PUBLIC_REGISTRATION_ENABLED=false

HL7_MLLP_ENABLED=true
HL7_MLLP_HOST=0.0.0.0
HL7_MLLP_PORT=2575
HL7_MLLP_RESPONSE_TIMEOUT_MS=15000
HL7_RECEIVING_APPLICATION=XPathLIMS
HL7_RECEIVING_FACILITY=YourLab
HL7_DEFAULT_OUTBOUND_HOST=
HL7_DEFAULT_OUTBOUND_PORT=2575

MAVIANCE_ENABLED=false
MAVIANCE_BASE_URL=https://api.smobilpay.com/s3papi
MAVIANCE_API_VERSION=3.0.0
MAVIANCE_REQUEST_FORMAT=form
MAVIANCE_TIMEOUT_MS=15000
MAVIANCE_ACCESS_TOKEN=
MAVIANCE_ACCESS_SECRET=
MAVIANCE_WEBHOOK_SECRET=
MAVIANCE_MTN_MERCHANT=
MAVIANCE_MTN_SERVICE_ID=
MAVIANCE_MTN_PAYITEM_ID=
MAVIANCE_ORANGE_MERCHANT=
MAVIANCE_ORANGE_SERVICE_ID=
MAVIANCE_ORANGE_PAYITEM_ID=

DMS_STORAGE_PROVIDER=local
DMS_LOCAL_STORAGE_PATH=./storage/documents
DMS_MAX_FILE_BYTES=10485760
DMS_ALLOWED_MIME_TYPES=application/pdf,application/vnd.openxmlformats-officedocument.wordprocessingml.document,application/msword,image/png,image/jpeg,text/plain
S3_BUCKET_NAME=
S3_REGION=
S3_ENDPOINT=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

ZOHO_BOOKS_ENABLED=false
ZOHO_BOOKS_ACCOUNTS_BASE_URL=https://accounts.zoho.com
ZOHO_BOOKS_API_BASE_URL=/books/v3/
ZOHO_BOOKS_CLIENT_ID=
ZOHO_BOOKS_CLIENT_SECRET=
ZOHO_BOOKS_REDIRECT_URI=
ZOHO_BOOKS_REFRESH_TOKEN=
ZOHO_BOOKS_ORGANIZATION_ID=
ZOHO_BOOKS_WEBHOOK_SECRET=

MFA_TOTP_ISSUER=OLYVIA
MFA_ENFORCED=false
MFA_ENFORCED_ROLES=super_admin,admin

# Production policy permits AI drafting as staff-verified draft support only.
# Use local Ollama by default; set AI_API_BASE_URL to the internal Ollama URL in hosted deployments.
AI_PROVIDER=ollama
AI_API_BASE_URL=http://localhost:11434
AI_API_KEY=
AI_MODEL=qwen2.5:1.5b
AI_VALIDATED_MODEL_ENDPOINT=
AI_VALIDATED_MODEL_API_KEY=
# Render deploys keep Whisper disabled by default; enable it only with a Docker build arg that installs Whisper.
WHISPER_ENABLED=false
WHISPER_COMMAND=whisper
WHISPER_MODEL=base
WHISPER_LANGUAGE=en
WHISPER_TIMEOUT_MS=120000
WHISPER_MAX_AUDIO_BYTES=26214400
ORTHANC_BASE_URL=
OHIF_VIEWER_URL=
WSI_TILE_SERVER_URL=
COUCHDB_URL=
COUCHDB_DATABASE=xpath_offline
OCR_TESSERACT_BINARY=tesseract
OCR_TESSERACT_LANG=eng+fra
OCR_NATIVE_ENABLED=true
OCR_MAX_PDF_PAGES=8
OCR_PDF_TEXT_MIN_CHARS=24

GPS_PROVIDER=browser_geolocation
COURIER_PROVIDER=generic_webhook
COURIER_API_BASE_URL=
COURIER_API_KEY=
COURIER_WEBHOOK_SECRET=
TEMPERATURE_LOGGER_PROVIDER=generic_webhook
TEMPERATURE_LOGGER_WEBHOOK_SECRET=
SPECIMEN_TEMP_MIN_CELSIUS=2
SPECIMEN_TEMP_MAX_CELSIUS=30

SMS_PROVIDER=generic
SMS_API_BASE_URL=
SMS_API_KEY=
WHATSAPP_PROVIDER=meta_cloud
WHATSAPP_API_BASE_URL=https://graph.facebook.com/v21.0
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

OFFLINE_SYNC_ENABLED=true

LEICA_PROCESSOR_API_TOKEN=
LEICA_PROCESSOR_WEBHOOK_SECRET=
LEICA_STAINER_API_TOKEN=
LEICA_STAINER_WEBHOOK_SECRET=
ROCHE_SCANNER_API_TOKEN=
ROCHE_SCANNER_WEBHOOK_SECRET=
VENDOR_INTEGRATION_TIMEOUT_MS=10000

NOTIFICATION_EMAIL_ENABLED=false
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=OLYVIA
SMTP_USE_TLS=true
SMTP_USE_SSL=false
