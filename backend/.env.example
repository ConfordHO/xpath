PORT=4000
NODE_ENV=production
TRUST_PROXY=true
CORS_ORIGIN=http://localhost:5173,https://xpath-two.vercel.app,https://x-path.vercel.app

DATABASE_URL=postgresql://username:password@host:5432/xpath
DATABASE_SSL_MODE=require
POSTGRES_STATE_TABLE=app_state
POSTGRES_STATE_ID=primary
POSTGRES_EXTERNAL_HOST_SUFFIX=oregon-postgres.render.com

# Optional one-time migration source
LEGACY_MONGODB_URI=
LEGACY_MONGODB_DB_NAME=xpath_lims
LEGACY_MONGODB_COLLECTION=app_state

JWT_SECRET=replace-with-a-long-random-secret
JWT_ISSUER=xpath-backend
JWT_AUDIENCE=xpath-clients
JWT_EXPIRY=7d

GENERAL_RATE_LIMIT_WINDOW_MS=60000
GENERAL_RATE_LIMIT_MAX=400
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=20

HL7_MLLP_ENABLED=true
HL7_MLLP_HOST=0.0.0.0
HL7_MLLP_PORT=2575
HL7_MLLP_RESPONSE_TIMEOUT_MS=15000
HL7_RECEIVING_APPLICATION=XPathLIMS
HL7_RECEIVING_FACILITY=YourLab
HL7_DEFAULT_OUTBOUND_HOST=
HL7_DEFAULT_OUTBOUND_PORT=2575

MAVIANCE_ENABLED=false
MAVIANCE_BASE_URL=https://api.smobilpay.com/s3papi
MAVIANCE_API_VERSION=3.0.0
MAVIANCE_REQUEST_FORMAT=form
MAVIANCE_TIMEOUT_MS=15000
MAVIANCE_ACCESS_TOKEN=
MAVIANCE_ACCESS_SECRET=
MAVIANCE_WEBHOOK_SECRET=
MAVIANCE_MTN_MERCHANT=
MAVIANCE_MTN_SERVICE_ID=
MAVIANCE_MTN_PAYITEM_ID=
MAVIANCE_ORANGE_MERCHANT=
MAVIANCE_ORANGE_SERVICE_ID=
MAVIANCE_ORANGE_PAYITEM_ID=

DMS_STORAGE_PROVIDER=local
DMS_LOCAL_STORAGE_PATH=./storage/documents
DMS_MAX_FILE_BYTES=10485760
DMS_ALLOWED_MIME_TYPES=application/pdf,application/vnd.openxmlformats-officedocument.wordprocessingml.document,application/msword,image/png,image/jpeg,text/plain
S3_BUCKET_NAME=
S3_REGION=
S3_ENDPOINT=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

LEICA_PROCESSOR_API_TOKEN=
LEICA_PROCESSOR_WEBHOOK_SECRET=
LEICA_STAINER_API_TOKEN=
LEICA_STAINER_WEBHOOK_SECRET=
ROCHE_SCANNER_API_TOKEN=
ROCHE_SCANNER_WEBHOOK_SECRET=
VENDOR_INTEGRATION_TIMEOUT_MS=10000

NOTIFICATION_EMAIL_ENABLED=false
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=X.PATH Labs
SMTP_USE_TLS=true
SMTP_USE_SSL=false
